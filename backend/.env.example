# Backend — Environment Variables
# Copy this to .env and fill in the values

PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/wellmora?retryWrites=true&w=majority
ACCESS_TOKEN_SECRET=replace_with_long_random_string_min_32_chars
REFRESH_TOKEN_SECRET=replace_with_another_long_random_string_min_32_chars
CLIENT_URL=https://your-customer-site.vercel.app
NODE_ENV=production
